# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# foray-specific
/data/
classifier-log.jsonl
foray-sync.log
public/foray-bookmarklet-url.json

# Prisma — generated client (regenerated on `pnpm prisma generate`)
/src/generated/

# Dev-only one-off scripts (fixtures, manual repro tools — NOT shipped)
scripts/dev/

# Visual companion brainstorm sessions
.superpowers/

# Claude Code harness runtime data (hook decision log, prepush-skip flag)
.claude/.devkit/

# Claude Code agent worktrees — git worktrees that must NEVER be committed
# (committing creates orphan gitlinks with no .gitmodules → CI checkout fails)
.claude/worktrees/

