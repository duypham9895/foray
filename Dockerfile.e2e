# syntax=docker/dockerfile:1.7
# =============================================================================
# foray — E2E test image
# Used by docker-compose.e2e.yml for reproducible Playwright test runs.
# Includes Playwright browsers + full app build. Expects Postgres via compose.
# =============================================================================

FROM node:20-bookworm-slim AS base
WORKDIR /app

ENV DATABASE_URL=postgresql://foray_e2e:foray_e2e@db:5432/foray_e2e
ENV APP_PASSWORD=test-password-e2e
ENV APP_SESSION_SECRET=test-session-secret-for-e2e-only-32chars
ENV ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ENV ANTHROPIC_API_KEY=test-anthropic-key
ENV NODE_ENV=test
ENV NODE_OPTIONS=--max-old-space-size=4096

RUN corepack enable && corepack prepare pnpm@10.29.3 --activate

# Install Playwright system deps (Chromium needs these on Debian slim)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 libcups2 \
    libdrm2 libdbus-1-3 libxkbcommon0 libatspi2.0-0 libxcomposite1 \
    libxdamage1 libxfixes3 libxrandr2 libgbm1 libpango-1.0-0 \
    libcairo2 libasound2 libwayland-client0 \
    && rm -rf /var/lib/apt/lists/*

# ---- deps ----
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile
RUN pnpm exec playwright install --with-deps chromium

# ---- build ----
COPY . .
RUN pnpm prisma generate
RUN pnpm build

# ---- run e2e ----
CMD ["sh", "-c", "pnpm prisma migrate deploy && pnpm seed && pnpm exec playwright test"]
