# =============================================================================
# foray — Environment Configuration
# =============================================================================
# Copy to .env.local for Path A (native dev) or .env for Path B (full Docker).
# Never commit .env.local or .env — they're gitignored.
# Run `openssl rand -hex 32` to generate ENCRYPTION_KEY.

# -----------------------------------------------------------------------------
# Single-user gate
# -----------------------------------------------------------------------------
# Password the owner enters at /login. Long, random, ≥12 chars, not your real password.
APP_PASSWORD=change-me-to-something-strong

# iron-session cookie encryption key (≥32 chars; required by AUTH-01).
# Generate with: openssl rand -hex 32
APP_SESSION_SECRET=

# -----------------------------------------------------------------------------
# Encryption (required)
# -----------------------------------------------------------------------------
# 64 hex chars (32 bytes). Generate with: openssl rand -hex 32
# Used to encrypt Gmail OAuth refresh tokens at rest in the DB.
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Anthropic API (required for LLM classifier fallback)
# -----------------------------------------------------------------------------
# Get at https://console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Google OAuth (required for Gmail integration)
# -----------------------------------------------------------------------------
# Set up at https://console.cloud.google.com — see SETUP.md "Connecting Gmail".
# Stay in OAuth Test mode (only your own email allowed).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Path A (native dev, db in Docker, app on host): use localhost.
# Path B (full Docker): compose overrides this to use 'db' hostname automatically.
DATABASE_URL=postgresql://foray:foray@localhost:5432/foray

# -----------------------------------------------------------------------------
# Classifier
# -----------------------------------------------------------------------------
# Confidence threshold above which auto-classification updates application status.
# Below threshold → review queue. See ADR-0006.
CLASSIFIER_AUTO_THRESHOLD=0.85

# -----------------------------------------------------------------------------
# Postgres credentials (consumed by docker-compose db service)
# -----------------------------------------------------------------------------
POSTGRES_USER=foray
POSTGRES_PASSWORD=foray
POSTGRES_DB=foray
